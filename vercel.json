{
  "version": 2,
  "buildCommand": "pnpm build:vercel",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/trpc/:path*", "destination": "/api/trpc" },
    { "source": "/api/oauth/:path*", "destination": "/api/oauth" },
    { "source": "/api/csrf-token", "destination": "/api/csrf" },
    { "source": "/manus-storage/:path*", "destination": "/api/storage" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
